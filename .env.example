DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_TIMEZONE=-05:00
DB_CONNECTION_TIMEOUT=20000

JWT_SECRET=
REFRESH_TOKEN_SECRET=   # Opcional: Si no se provee, se usa JWT_SECRET + "_refresh"
JWT_ACCESS_EXPIRY=4h

API_PREFIX=/api/v1
LOG_LEVEL=debug
NODE_ENV=development
PORT=3600

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Moodle configuration
MOODLE_URL=http://localhost:8080
MOODLE_API_TOKEN=moodle_api_token_change_in_production
MOODLE_SSO_SECRET=moodle_sso_secret_key_change_in_production

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0